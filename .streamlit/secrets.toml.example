# Copy this file to .streamlit/secrets.toml for local development,
# or paste the same values into Streamlit Community Cloud -> App settings -> Secrets.

DB_URL = "mysql+mysqlconnector://USERNAME:PASSWORD@HOST:3306/DATABASE_NAME"

# Alternative supported structure in app.py:
# [database]
# url = "mysql+mysqlconnector://USERNAME:PASSWORD@HOST:3306/DATABASE_NAME"